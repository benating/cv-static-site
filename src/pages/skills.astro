---
import BaseLayout from "../layouts/BaseLayout.astro";

const skillGroups = [
  {
    title: "Cloud & Infrastructure",
    skills: ["AWS", "Kubernetes", "Infrastructure Automation", "Disaster Recovery"],
  },
  {
    title: "Platform Engineering",
    skills: ["Platform Engineering", "Production Operations", "Reliability Strategy"],
  },
  {
    title: "Observability & Incident",
    skills: ["Incident Management", "Observability", "SLO / SLI Design"],
  },
  {
    title: "CI/CD & Automation",
    skills: ["CI/CD", "Infrastructure as Code", "Deployment Automation"],
  },
  {
    title: "Leadership & Process",
    skills: ["Team Leadership", "Operational Excellence", "Technical Hiring", "Mentoring"],
  },
];
---

<BaseLayout>
  <section class="skills-page fade-in">
    <h2 class="section-title">Skills</h2>

    <div class="skills-grid">
      {
        skillGroups.map((group) => (
          <div class="skill-group fade-in">
            <h3 class="skill-group-title">{group.title}</h3>
            <div class="skill-tags">
              {group.skills.map((skill) => <span class="skill-tag">{skill}</span>)}
            </div>
          </div>
        ))
      }
    </div>

    <div class="certs-section fade-in fade-in-delay-2">
      <h2 class="section-title">Certifications</h2>
      <a
        href="https://www.credly.com/badges/cc1e8703-b3f1-4d86-a67f-c03fef88897d"
        target="_blank"
        rel="noopener"
        class="cert-card"
      >
        <div class="cert-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="6"/>
            <path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/>
          </svg>
        </div>
        <div class="cert-info">
          <div class="cert-name">Certified Kubernetes Administrator (CKA)</div>
          <div class="cert-issuer">Linux Foundation</div>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .skills-page {
    max-width: 700px;
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .skill-group {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.3s ease;
  }

  .skill-group:hover {
    border-color: var(--border-hover);
  }

  .skill-group-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-primary);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.35rem 0.75rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .skill-tag:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
  }

  .certs-section {
    margin-top: 0;
  }

  .cert-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .cert-card:hover {
    border-color: var(--accent-primary);
    box-shadow: 0 0 20px rgba(100, 255, 218, 0.05);
  }

  .cert-icon {
    color: var(--accent-primary);
    flex-shrink: 0;
  }

  .cert-info {
    flex: 1;
  }

  .cert-name {
    font-family: var(--font-mono);
    font-size: 0.925rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .skill-group {
      padding: 1rem;
    }

    .cert-card {
      padding: 1rem;
    }
  }
</style>
