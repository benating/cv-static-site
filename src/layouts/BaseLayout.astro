---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bernard Ting - CV / Resume" />
    <title>Bernard's CV</title>
  </head>
  <body>
    <Header />
    <main class="container" style="min-height: calc(100vh - var(--header-height) - 120px); padding-top: calc(var(--header-height) + 2rem); padding-bottom: 3rem;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
